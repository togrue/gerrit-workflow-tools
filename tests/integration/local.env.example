# Copy this file to `local.env` in the same directory and adjust.
# `local.env` is gitignored — put personal hostnames, ports, and Docker SSH here.
#
# Example: Gerrit on a Linux box you reach as `ssh lenovo`, HTTP at http://lenovo-pc:8081
# (your DNS / hosts file should resolve lenovo-pc to that machine).

GERRIT_IT_PUBLIC_HOST=lenovo-pc
GERRIT_IT_HOST_PORT_HTTP=8081
# Docker engine on the remote host (use your SSH config Host name after ssh://).
GERRIT_IT_DOCKER_HOST=ssh://lenovo

# Optional:
# GERRIT_IT_HOST_PORT_SSH=29418
# GERRIT_IT_KEEP_CONTAINER=1
# GERRIT_IT_HTTP_ADMIN_PASS=your-admin-http-password
# GERRIT_IT_RUN_ID=debug1
