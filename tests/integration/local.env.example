# Copy to `local.env` (gitignored) and adjust.
#
# These tests START a dedicated Gerrit container on the Docker host. The HTTP/SSH
# ports below are HOST ports that must be FREE on that machine — not “the port
# my other Gerrit already uses” unless you stop that service or pick other ports.
#
# Example: run Docker on Lenovo via SSH; reach Gerrit from your PC at http://lenovo-pc:8082
# (use 8082 if something else already uses 8081 on Lenovo).

GERRIT_IT_PUBLIC_HOST=lenovo-pc
GERRIT_IT_HOST_PORT_HTTP=8082
GERRIT_IT_HOST_PORT_SSH=29419
# Docker on the remote host. If `ssh lenovo docker ps` works but pytest does not, try:
# GERRIT_IT_DOCKER_HOST=ssh://YOUR_LINUX_USER@lenovo-pc
GERRIT_IT_DOCKER_HOST=ssh://lenovo

# Optional:
# GERRIT_IT_KEEP_CONTAINER=1
# GERRIT_IT_HTTP_ADMIN_PASS=your-admin-http-password
# GERRIT_IT_RUN_ID=debug1
