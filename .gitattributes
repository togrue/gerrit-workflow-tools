# Default: normalize line endings in the index; check out with LF for consistency (CI, containers).
* text=auto eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary

*.zip binary
*.gz binary
*.7z binary
